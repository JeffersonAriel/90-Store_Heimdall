<IfModule mod_rewrite.c>
    RewriteEngine On

    # ── REGRA 1: Nunca redirecionar a pasta assets/ (JS, CSS, fontes do Vue) ──
    RewriteRule ^assets/ - [L]

    # ── REGRA 2: Nunca redirecionar favicon, robots, manifest etc. ───────────
    RewriteRule ^(favicon\.ico|robots\.txt|manifest\.json|logo\.png|\.well-known/.*)$ - [L]

    # ── REGRA 3: Instalador (se não estiver instalado, vai pro wizard) ────────
    RewriteCond %{DOCUMENT_ROOT}/backend/installed.lock !-f
    RewriteRule ^(.*)$ backend/public/index.php [L,QSA]

    # ── REGRA 4: Arquivos estáticos do Backend (build/, storage/) ─────────────
    RewriteRule ^(build|storage)(/.*)?$ /backend/public/$1$2 [L]

    # ── REGRA 5: Rotas do Backend (painel, api) → Laravel ────────────────────
    RewriteRule ^(heimdall|install|api)(/.*)?$ /backend/public/index.php [L,QSA]

    # ── REGRA 6: SPA Vue — qualquer outra rota → index.html ──────────────────
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.html [L]

</IfModule>

# ── MIME types corretos para módulos ES (crítico para Chrome/Edge) ────────────
<IfModule mod_mime.c>
    AddType application/javascript  .js
    AddType application/javascript  .mjs
    AddType text/css                .css
    AddType image/svg+xml           .svg
    AddType font/woff2              .woff2
    AddType font/woff               .woff
    AddType application/json        .json
</IfModule>

# ── Compressão gzip ────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE application/javascript text/css text/html
</IfModule>

# ── Cache de longa duração para assets com hash no nome ───────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType application/javascript  "access plus 1 year"
    ExpiresByType text/css                "access plus 1 year"
    ExpiresByType font/woff2              "access plus 1 year"
    ExpiresByType image/png               "access plus 1 month"
    ExpiresByType image/jpeg              "access plus 1 month"
    ExpiresByType image/svg+xml           "access plus 1 month"
</IfModule>
